{
  "name": "cortex-cm6-bundle",
  "private": true,
  "description": "One-time esbuild bundle of CodeMirror 6 for the offline, no-build Cortex web UI. Build: npm install && npm run build (outputs ../cm6.js).",
  "scripts": {
    "build": "esbuild entry.js --bundle --format=iife --minify --legal-comments=none --outfile=../cm6.js"
  },
  "dependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.8",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.1",
    "@lezer/highlight": "^1.2.1"
  },
  "devDependencies": {
    "esbuild": "^0.24.2"
  }
}
